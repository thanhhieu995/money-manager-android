<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.bottomNavigation.statistic.StatisticCategoryActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/activity_statistic_category_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_200"
        app:title=""
        app:contentInsetStartWithNavigation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/activity_statistic_category_toolbarContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Back Button (Góc trái) -->
            <ImageButton
                android:id="@+id/activity_statistic_category_backButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_baseline_navigate_before_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorControlNormal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Title hiện tại -->
            <TextView
                android:id="@+id/activity_statistic_category_titleCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="?android:attr/textColorPrimary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Title tiếp theo -->
            <TextView
                android:id="@+id/activity_statistic_category_titleIncoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incoming"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:alpha="0"
                android:textColor="?android:attr/textColorPrimary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <LinearLayout
        android:id="@+id/activity_statistic_category_layout_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- Hàng đầu tiên -->

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/activity_statistic_category_layout_edit_line_one"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="@color/purple_500"
            android:padding="16dp">

            <ImageView
                android:id="@+id/activity_statistic_category_layout_edit_line_one_btn_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_baseline_close_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/activity_statistic_category_layout_edit_line_one_btn_delete" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/activity_statistic_category_layout_edit_line_one_btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Delete"
                android:src="@drawable/ic_baseline_delete_outline_24"
                app:layout_constraintEnd_toStartOf="@+id/activity_statistic_category_layout_edit_line_one_btn_more"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/activity_statistic_category_layout_edit_line_one_btn_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="More"
                android:src="@drawable/ic_baseline_more_vert_24"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Hàng thứ hai -->
        <LinearLayout
            android:id="@+id/activity_statistic_category_layout_edit_line_two"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:background="@color/purple_700"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/activity_statistic_category_layout_edit_line_two_selected_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:text="0 items selected" />

            <TextView
                android:id="@+id/activity_statistic_category_layout_edit_line_two_selected_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="Total: 0" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/activity_statistic_category_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>