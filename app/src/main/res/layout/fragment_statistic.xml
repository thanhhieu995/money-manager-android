<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stats_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/fragment_statistic_layout_topYear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fragment_daily_navigate_search">

        <ImageView
            android:id="@+id/fragment_statistic_month_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_baseline_navigate_before_24" />

        <TextView
            android:id="@+id/fragment_statistic_month_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Apr 2025"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/fragment_statistic_month_next"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_baseline_navigate_next_24" />
    </LinearLayout>
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/fragment_statistic_toggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_gravity="center"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/fragment_statistic_btnExpense"
        android:backgroundTint="@android:color/transparent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fragment_statistic_btnIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/ToggleButtonStyle"
            android:text="Income"
            app:cornerRadius="16dp"
            app:strokeColor="@color/income"
            app:strokeWidth="2dp"
            android:textColor="@color/toggle_button_income_text_selector"
            android:backgroundTint="@color/toggle_button_income_background_selector"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fragment_statistic_btnExpense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/ToggleButtonStyle"
            android:text="Expense"
            app:cornerRadius="16dp"
            app:strokeColor="@color/red"
            app:strokeWidth="2dp"
            android:textColor="@color/toggle_button_expense_text_selector"
            android:backgroundTint="@color/toggle_button_expense_background_selector"/>
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/chartContainer">

            <TextView
                android:id="@+id/fragment_statistic_noDataText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="16dp"
                android:text="No data available"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@+id/fragment_statistic_pieChart"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.1" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guidelineEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.9" />

            <!-- PieChart ở giữa 2 guideline -->
            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/fragment_statistic_pieChart"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintStart_toStartOf="@id/guidelineStart"
                app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintDimensionRatio="1:1" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Danh sách phân loại -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/fragment_statistic_statsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
