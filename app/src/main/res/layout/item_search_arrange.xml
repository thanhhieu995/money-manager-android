<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Mỗi lựa chọn là một dòng -->
    <LinearLayout
        android:id="@+id/optionTotalLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/search_optionTotal"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="All" />

        <ImageView
            android:id="@+id/search_optionTotalCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_baseline_check_24"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/optionWeeklyLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/search_optionWeekly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Weekly"
            />

        <ImageView
            android:id="@+id/search_optionWeeklyCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_baseline_check_24"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/optionMonthlyLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/search_optionMonthly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Monthly"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/search_optionMonthlyCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_baseline_check_24"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/optionYearlyLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/search_optionYearly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Yearly"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/search_optionYearlyCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_baseline_check_24"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/search_optionCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:padding="16dp"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:textStyle="bold"/>
</LinearLayout>
