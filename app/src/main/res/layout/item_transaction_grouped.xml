<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Header: Ngày + Tổng thu/chi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/transaction_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="05 Mon" />

        <TextView
            android:id="@+id/transaction_income"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0đ"
            android:gravity="end"
            android:textColor="@color/income" />

        <TextView
            android:id="@+id/transaction_total_expense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2.000đ"
            android:textColor="@color/red"
            android:gravity="end" />
    </LinearLayout>

    <!-- Gạch mờ phân cách -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider" /> <!-- Màu đen mờ 13% -->

    <!-- Container để thêm các dòng giao dịch con -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/transaction_container"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
