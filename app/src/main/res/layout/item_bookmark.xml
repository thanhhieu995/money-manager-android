<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Foreground content (sẽ được trượt sang trái để hiện nút Delete) -->
    <LinearLayout
        android:id="@+id/item_bookmark_foreground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/item_bookmark_deleteIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_baseline_remove_circle_24"
            android:visibility="visible" />

        <!-- Cột trái: Date & Category -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_bookmark_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/5/2025"
                android:textColor="#888888"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/item_bookmark_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hair Cut"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Cột giữa: Content & Account -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_bookmark_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuition fee" />

            <TextView
                android:id="@+id/item_bookmark_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash"
                android:textColor="#888888"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Cột phải: Amount -->
        <TextView
            android:id="@+id/item_bookmark_amount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:text="40.000đ"
            android:textColor="#FF3B30" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>