<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top: Navigation -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/add_transaction_btn_back"
            android:src="@drawable/ic_baseline_navigate_before_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/add_transaction_title"
            android:text="Expense"
            android:textSize="18sp"
            android:layout_marginStart="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Tabs: Income, Expense, Transfer -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/add_transaction_btn_income"
            android:text="Income"
            android:backgroundTint="@color/transparent"
            android:textColor="@color/black"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_marginEnd="8dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/add_transaction_btn_expense"
            android:text="Expense"
            android:backgroundTint="@color/red"
            android:textColor="@color/white"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Date + Fields -->
    <TextView
        android:id="@+id/add_transaction_date"
        android:text="26/4/25 (Sat)"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/add_transaction_amount"
        android:hint="Amount"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/add_transaction_edtCategory"
        android:hint="Category"
        android:focusable="false"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText
        android:id="@+id/add_transaction_edtAccount"
        android:hint="Account"
        android:focusable="false"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <EditText
        android:id="@+id/add_transaction_edtNote"
        android:hint="Note"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Custom Number Pad -->

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/add_transaction_btnSave"
            android:text="Save"
            android:textColor="@color/white"
            android:backgroundTint="@color/red"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_marginEnd="8dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/add_transaction_btnContinue"
            android:text="Continue"
            android:textColor="@color/black"
            android:backgroundTint="@color/white"
            android:layout_width="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_height="wrap_content" />
    </LinearLayout>


</LinearLayout>
