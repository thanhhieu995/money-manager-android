<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:id="@+id/monthly_item_month"
    android:background="@android:color/white">

    <!-- Dòng tháng + khoảng ngày -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/monthly_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="May"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/monthly_arrange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01-05 ~ 31-05"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/monthly_income"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.000.000đ"
        android:layout_weight="1"
        android:textColor="#007AFF"
        android:textSize="14sp" />

    <!-- Dòng thu nhập, chi phí, tổng -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/monthly_expense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2.017.725đ"
            android:textColor="#FF3B30"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/monthly_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-1.017.725đ"
            android:textColor="#000000"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
