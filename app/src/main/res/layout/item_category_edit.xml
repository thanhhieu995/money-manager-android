<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/item_category_edit_deleteIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="8dp"
        android:src="@drawable/ic_baseline_remove_circle_24"
        android:visibility="visible" />

    <!-- Name & Subcategories -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/item_category_edit_tvCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍜 Food"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/item_category_edit_tvSubcategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lunch, Dinner, Coffee"
            android:textSize="12sp"
            android:textColor="#888888" />
    </LinearLayout>

    <!-- ✨ Icon edit bên phải -->
    <ImageView
        android:id="@+id/item_category_edit_editIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_baseline_edit_grey_24"
        android:contentDescription="Edit"
        android:padding="4dp"/>
</LinearLayout>
