<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Left: Date and Category -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/item_transaction_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Food"
            android:maxLines="1"
            android:ellipsize="end"
            android:scrollHorizontally="true"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"/>
        <TextView
            android:id="@+id/item_transaction_child_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Breakfast"
            android:maxLines="1"
            android:ellipsize="end"
            android:scrollHorizontally="true"
            android:textColor="#888888"
            android:textSize="14sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/item_transaction_content"
            android:text="Tuition fee"
            android:maxLines="1"
            android:ellipsize="end"
            android:scrollHorizontally="true"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/item_transaction_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cash"
            android:maxLines="1"
            android:ellipsize="end"
            android:scrollHorizontally="true"
            android:textColor="#888888"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Right: Amount -->
    <TextView
        android:id="@+id/item_transaction_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="40.000đ"
        android:maxLines="1"
        android:ellipsize="end"
        android:scrollHorizontally="true"
        android:textColor="#FF3B30"
        android:gravity="end"/>
</LinearLayout>
